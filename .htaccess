# ============================================================
# guide-achat-cbd.com — .htaccess
# Hostinger Apache — SEO + Sécurité + Performance
# ============================================================

Options -Indexes
ServerSignature Off

# ============================================================
# 1. HTTPS FORCÉ
# ============================================================
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ============================================================
# 2. WWW → NON-WWW (canonical)
# ============================================================
RewriteCond %{HTTP_HOST} ^www\.guide-achat-cbd\.com$ [NC]
RewriteRule ^ https://guide-achat-cbd.com%{REQUEST_URI} [R=301,L]

# ============================================================
# 3. URLs PROPRES — suppression de l'extension .html
# ============================================================

# Si le fichier existe tel quel → servir directement
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Si le dossier existe → servir directement
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# /blog/article → /blog/article.html
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+)$ $1.html [L]

# /hub/page → /hub/page.html
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+)$ $1.html [L]

# mentions-legales → mentions-legales.html
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^.]+)$ $1.html [L]

# ============================================================
# 4. SLASH FINAL — suppression (canonical propre)
# ============================================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# ============================================================
# 5. PAGE 404 CUSTOM
# ============================================================
ErrorDocument 404 /404.html

# ============================================================
# 6. CACHE — Performance CWV
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — court (contenu qui change)
  ExpiresByType text/html                  "access plus 1 hour"

  # CSS / JS
  ExpiresByType text/css                   "access plus 1 year"
  ExpiresByType application/javascript     "access plus 1 year"
  ExpiresByType text/javascript            "access plus 1 year"

  # Images
  ExpiresByType image/webp                 "access plus 1 year"
  ExpiresByType image/jpeg                 "access plus 1 year"
  ExpiresByType image/png                  "access plus 1 year"
  ExpiresByType image/svg+xml              "access plus 1 year"
  ExpiresByType image/gif                  "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon  "access plus 1 year"

  # Fonts
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType font/woff                  "access plus 1 year"
  ExpiresByType application/font-woff2     "access plus 1 year"

  # Données
  ExpiresByType application/json           "access plus 0 seconds"
  ExpiresByType text/xml                   "access plus 0 seconds"
</IfModule>

# ============================================================
# 7. COMPRESSION GZIP
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2
  AddOutputFilterByType DEFLATE font/woff
</IfModule>

# ============================================================
# 8. HEADERS SÉCURITÉ
# ============================================================
<IfModule mod_headers.c>

  # Anti-clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"

  # Anti-XSS
  Header always set X-XSS-Protection "1; mode=block"

  # No MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Referrer Policy (SEO-safe : envoie l'origine sur HTTPS)
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Cache-Control sur assets statiques
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|ico|woff2|woff|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Cache-Control HTML
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  # Permissions Policy (désactive fonctions inutiles)
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

</IfModule>

# ============================================================
# 9. TYPES MIME
# ============================================================
<IfModule mod_mime.c>
  AddType image/webp                  .webp
  AddType font/woff2                  .woff2
  AddType font/woff                   .woff
  AddType application/json            .json
  AddType text/plain                  .txt
</IfModule>

# ============================================================
# 10. BLOQUER ACCÈS FICHIERS SENSIBLES
# ============================================================
<FilesMatch "(^\.htaccess|\.htpasswd|\.git|\.env|composer\.json|package\.json)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# ============================================================
# 11. BLOQUER BOTS MALVEILLANTS (spam crawlers)
# ============================================================
RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|MJ12bot|DotBot|SemrushBot|BLEXBot) [NC]
RewriteRule .* - [F,L]

# ============================================================
# 12. SITEMAP + ROBOTS — accès direct garanti
# ============================================================
RewriteRule ^sitemap\.xml$ /sitemap.xml [L]
RewriteRule ^robots\.txt$ /robots.txt [L]
RewriteRule ^llms\.txt$ /llms.txt [L]
RewriteRule ^llms-full\.txt$ /llms-full.txt [L]
